---
import { site } from "../config/site";

const googleUrl = site.googleMapsProfileUrl;
---

<div id="reviews-section" class="reviews-container">
  <!-- Skeleton / loading state -->
  <div class="reviews-header" id="reviews-header">
    <div class="skeleton skeleton-title"></div>
    <div class="skeleton skeleton-subtitle"></div>
  </div>
  <div class="reviews-grid" id="reviews-grid">
    <div class="review-card card skeleton-card"><div class="skeleton skeleton-block"></div></div>
    <div class="review-card card skeleton-card"><div class="skeleton skeleton-block"></div></div>
    <div class="review-card card skeleton-card"><div class="skeleton skeleton-block"></div></div>
  </div>
  <div class="reviews-cta" id="reviews-cta" style="display:none;">
    <a href={googleUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
      Ver todas en Google
    </a>
  </div>
</div>

<script>
  async function loadReviews() {
    const headerEl = document.getElementById("reviews-header");
    const gridEl = document.getElementById("reviews-grid");
    const ctaEl = document.getElementById("reviews-cta");
    if (!headerEl || !gridEl || !ctaEl) return;

    try {
      const res = await fetch("/api/reviews");
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      // Header: rating + count
      const stars = renderStars(data.rating ?? 0);
      headerEl.innerHTML = `
        <div class="reviews-rating">
          <span class="stars">${stars}</span>
          <span class="rating-number">${data.rating?.toFixed(1) ?? "—"}</span>
        </div>
        <p class="reviews-count">${data.userRatingCount ?? 0} reseñas en Google</p>
      `;

      // Review cards
      const reviews: any[] = data.reviews ?? [];
      if (reviews.length === 0) {
        gridEl.innerHTML = `<p style="color:var(--color-text-muted)">No hay reseñas disponibles.</p>`;
      } else {
        gridEl.innerHTML = reviews
          .map(
            (r: any) => `
          <article class="review-card card">
            <div class="review-top">
              ${r.profilePhotoUrl ? `<img src="${r.profilePhotoUrl}" alt="" class="review-avatar" width="40" height="40" loading="lazy" />` : ""}
              <div>
                <strong class="review-author">${escHtml(r.authorName ?? "Anónimo")}</strong>
                ${r.relativePublishTimeDescription ? `<span class="review-date">${escHtml(r.relativePublishTimeDescription)}</span>` : ""}
              </div>
            </div>
            <div class="review-stars">${renderStars(r.rating ?? 0)}</div>
            <p class="review-text">${escHtml(truncate(r.text ?? "", 280))}</p>
          </article>`
          )
          .join("");
      }

      ctaEl.style.display = "";
    } catch (err) {
      console.error("Reviews fetch error:", err);
      headerEl.innerHTML = "";
      gridEl.innerHTML = `<p style="color:var(--color-text-muted)">No se pudieron cargar las reseñas.</p>`;
    }
  }

  function renderStars(rating: number): string {
    const full = Math.round(rating);
    return "★".repeat(full) + "☆".repeat(5 - full);
  }

  function truncate(str: string, max: number): string {
    if (str.length <= max) return str;
    return str.slice(0, max).trimEnd() + "…";
  }

  function escHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  loadReviews();
  document.addEventListener("astro:after-swap", loadReviews);
</script>

<style>
  .reviews-container { text-align: center; }

  .reviews-header { margin-bottom: 1.5rem; }
  .reviews-rating { display: flex; align-items: center; justify-content: center; gap: .5rem; font-size: 1.5rem; }
  .stars { color: #f5a623; }
  .rating-number { font-weight: 700; color: var(--color-text); }
  .reviews-count { color: var(--color-text-muted); font-size: .95rem; }

  .reviews-grid {
    display: grid; gap: 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    text-align: left;
  }

  .review-card { display: flex; flex-direction: column; gap: .5rem; }
  .review-top { display: flex; align-items: center; gap: .75rem; }
  .review-avatar { border-radius: 50%; }
  .review-author { display: block; font-size: .95rem; }
  .review-date { font-size: .8rem; color: var(--color-text-muted); }
  .review-stars { color: #f5a623; font-size: .95rem; }
  .review-text { font-size: .9rem; color: var(--color-text-muted); line-height: 1.5; }

  .reviews-cta { margin-top: 1.5rem; }

  /* Skeleton animations */
  .skeleton { background: var(--color-bg-alt); border-radius: 6px; animation: pulse 1.5s infinite; }
  .skeleton-title { width: 200px; height: 28px; margin: 0 auto .5rem; }
  .skeleton-subtitle { width: 160px; height: 18px; margin: 0 auto; }
  .skeleton-card { min-height: 120px; }
  .skeleton-block { width: 100%; height: 80px; }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: .4; }
  }
</style>
