---
import Layout from "../components/Layout.astro";
import GoogleMapEmbed from "../components/GoogleMapEmbed.astro";
import CalComLazy from "../components/CalComLazy.astro";
import { site } from "../config/site";
import { buildWhatsAppLink } from "../utils/whatsapp";

const waLink = buildWhatsAppLink(site.whatsappNumberMain, site.whatsappDefaultMessage);
---

<Layout title="Contacto" description="Ponte en contacto con nosotros. WhatsApp, email, teléfono y dirección.">
  <section class="section">
    <div class="container">
      <h1 class="section-title">Contacto</h1>

      <div class="contact-layout">
        <div class="contact-info">
          <div class="contact-item">
            <h3>📞 Teléfono</h3>
            <a href={`tel:${site.phone.replace(/\s/g, "")}`}>{site.phone}</a>
          </div>
          <div class="contact-item">
            <h3>✉️ Email</h3>
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </div>
          <div class="contact-item">
            <h3>💬 WhatsApp</h3>
            <a href={waLink} target="_blank" rel="noopener noreferrer">
              Escríbenos por WhatsApp
            </a>
          </div>
          <div class="contact-item">
            <h3>📍 Dirección</h3>
            <p>{site.addressText}</p>
          </div>
          <div class="contact-links">
            <a href={site.instagramProfileUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
              Instagram
            </a>
            <a href={site.googleMapsProfileUrl} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
              Google Maps
            </a>
          </div>
        </div>

        <div class="contact-map">
          <GoogleMapEmbed src={site.googleMapsEmbedSrc} />
        </div>
      </div>

    </div>
  </section>

  <section class="section" id="cal-booking">
    <div class="container">
      <h2 class="section-title">Reserva tu cita</h2>
      <CalComLazy url={site.calUrl} />
    </div>
  </section>
</Layout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }
  .contact-info { display: flex; flex-direction: column; gap: 1.25rem; }
  .contact-item h3 { font-size: 1rem; margin-bottom: .25rem; color: var(--color-primary-dark); }
  .contact-item a,
  .contact-item p { font-size: .95rem; }
  .contact-links { display: flex; gap: .75rem; flex-wrap: wrap; margin-top: .5rem; }

  @media (max-width: 700px) {
    .contact-layout { grid-template-columns: 1fr; }
  }
</style>
